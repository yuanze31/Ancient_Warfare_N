{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.bandit_troops": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "summon_bandits": "query.scoreboard('bandit_summon') == 1 && query.scoreboard('new_summon') == 1"
            }
          ]
        },
        "summon_bandits": {
          "on_entry": [
            "/summon aw:bandit_soldier ~+1 ~+1 ~+1",
            "/summon aw:bandit_soldier ~+1 ~+1 ~-1",
            "/summon aw:bandit_archer ~-1 ~+1 ~-1",
            "/summon aw:bandit_soldier_horse ~ ~+1 ~",
            "/summon aw:bandit_archer_horse ~-1 ~+1 ~+1",
            "/summon aw:bandit_general_horse ~+1 ~+1 ~"
          ]
        }
      }
    }
  }
}
