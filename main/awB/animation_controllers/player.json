{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.player_troops": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "summon_player_troops": "query.scoreboard('player_summon') == 1 && query.scoreboard('new_summon') == 1"
            }
          ]
        },
        "summon_player_troops": {
          "on_entry": [
            "/summon aw:player_soldier ~+1 ~+1 ~+1",
            "/summon aw:player_soldier ~+1 ~+1 ~-1",
            "/summon aw:player_archer ~-1 ~+1 ~-1",
            "/summon aw:player_soldier_horse ~ ~+1 ~",
            "/summon aw:player_archer_horse ~-1 ~+1 ~+1",
            "/summon aw:player_general_horse ~+1 ~+1 ~"
          ]
        }
      }
    }
  }
}
