{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.viking_troops": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "condition": "query.scoreboard('viking_summon', 'minecraft:dummy') == 1 && query.scoreboard('new_summon', 'minecraft:dummy') == 1",
              "state": "summon_viking_troops"
            }
          ]
        },
        "summon_viking_troops": {
          "on_entry": [
            "/summon aw:viking_soldier ~+1 ~+1 ~+1",
            "/summon aw:viking_soldier ~+1 ~+1 ~-1",
            "/summon aw:viking_archer ~-1 ~+1 ~-1",
            "/summon aw:viking_soldier_horse ~ ~+1 ~",
            "/summon aw:viking_archer_horse ~-1 ~+1 ~+1",
            "/summon aw:viking_general_horse ~+1 ~+1 ~"
          ]
        }
      }
    }
  }
}
